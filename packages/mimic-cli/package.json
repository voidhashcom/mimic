{
  "name": "@voidhash/mimic-cli",
  "version": "1.0.0-beta.1",
  "type": "module",
  "main": "./src/index.ts",
  "bin": {
    "mimic": "./dist/bin.cjs"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "rm -rf ./dist && tsx build.ts && chmod +x ./dist/bin.cjs",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@voidhash/mimic": "workspace:*",
    "@voidhash/mimic-protocol": "workspace:*",
    "@voidhash/mimic-sdk": "workspace:*",
    "dotenv": "^16.4.7",
    "effect": "catalog:",
    "esbuild-register": "^3.6.0"
  },
  "devDependencies": {
    "@voidhash/tsconfig": "workspace:*",
    "esbuild": "^0.25.10",
    "tsup": "^6.1.3",
    "tsx": "^4.19.3",
    "typescript": "5.8.3"
  }
}
