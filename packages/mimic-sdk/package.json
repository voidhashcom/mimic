{
  "name": "@voidhash/mimic-sdk",
  "version": "1.0.0-beta.1",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./effect": {
      "types": "./src/effect/index.ts",
      "import": "./dist/effect/index.mjs",
      "require": "./dist/effect/index.cjs"
    }
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@voidhash/tsconfig": "workspace:*",
    "tsdown": "^0.18.2",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "@voidhash/mimic": "workspace:*",
    "effect": "catalog:"
  }
}
