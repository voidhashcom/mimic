{
  "name": "@voidhash/mimic-sdk",
  "version": "1.0.0-beta.18",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/voidhashcom/voidhash",
    "directory": "packages/mimic-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./effect": {
      "types": "./src/effect/index.ts",
      "import": "./dist/effect/index.mjs",
      "require": "./dist/effect/index.cjs"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@voidhash/tsconfig": "workspace:*",
    "tsdown": "^0.18.2",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "@voidhash/mimic": "workspace:*",
    "@voidhash/mimic-protocol": "workspace:*",
    "effect": "catalog:"
  }
}
