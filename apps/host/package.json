{
	"name": "@voidhash/mimic-host",
	"version": "0.1.0",
	"type": "module",
	"private": true,
	"scripts": {
		"dev": "bun run --watch src/index.ts",
		"build": "bun build ./src/index.ts --outdir ./dist --target bun --env disable --sourcemap=external",
		"start": "bun run dist/index.js",
		"typecheck": "tsgo --noEmit",
		"lint": "biome check .",
		"format": "biome format . --write"
	},
	"dependencies": {
		"@effect/platform-bun": "catalog:",
		"@voidhash/mimic": "workspace:*",
		"@voidhash/mimic-effect": "workspace:*",
		"effect": "catalog:"
	},
	"devDependencies": {
		"@voidhash/tsconfig": "workspace:*",
		"typescript": "^5"
	},
	"engines": {
		"bun": ">=1.2.20"
	}
}
